# API Keys & Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Anthropic (Claude API)
ANTHROPIC_API_KEY=
# Google Custom Search (for image references)
# Get API key: https://developers.google.com/custom-search/v1/introduction
# Create CSE: https://programmablesearchengine.google.com/
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Google OAuth credentials file (for Google Docs API)
# Download from: https://console.cloud.google.com/ → APIs & Services → Credentials
# Save as credentials.json in the project root (gitignored)
